@Library('git-aws-repo@jenkins-terraform') _

pipeline {
    agent any

    parameters {
        choice(name: 'ACTION',
               choices: ['plan','apply','destroy'],
               description: 'terraform action to perform')
        string(name: 'ZONE', defaultValue: '', description: 'AWS availability zone')
        choice(name: 'REGION',
               choices: ['N. Virginia','Ohio','...'],
               description: 'AWS region')
        choice(name: 'RESOURCE',
               choices: ['vpc','instance','container','s3'],
               description: 'resource type')
        string(name: 'NAME', defaultValue: '', description: 'resource name')
    }

    stages {
        stage('Validate Input') {
            steps {
                script {
                    
                    def validated = AWSResources(params.region, params.resource)
                    echo "Validated parameters: ${validated}"
                    env.AWS_REGION   = validated[0]
                    env.AWS_RESOURCE = validated[1]
                    env.RESOURCE_NAME = params.NAME
                    
                    def missing = []
                    if (!params.ZONE)   missing << 'zone'
                    if (!params.NAME)   missing << 'name'
                    if (missing) error("Missing: ${missing.join(', ')}")
                }
            }
        }

        stage('Render variables') {
            steps {
                script {
                    // your existing templating script can consume the three env vars
                    sh 'chmod +x scripts/update_files.sh && scripts/update_files.sh'
                }
            }
        }

        stage('Terraform Init') {
            steps {
                // credentials bound automatically by Jenkins config
                script {
                    terraformInit()   // call the groovy/templated step
                }
            }
        }

        stage('Terraform ${params.ACTION.capitalize()}') {
            steps {
                script {
                    switch (params.ACTION) {
                      case 'plan':
                          terraformPlan()
                          break
                      case 'apply':
                          terraformApply()
                          break
                      case 'destroy':
                          terraformDestroy()
                          break
                      default:
                          error("Unknown action ${params.ACTION}")
                    }
                }
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'terraform.tfvars', fingerprint: true
            cleanWs()
        }
        success {
            echo "${params.ACTION} completed for branch ${env.BRANCH_NAME}"
        }
    }
}